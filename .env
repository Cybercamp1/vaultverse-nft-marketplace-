# Copy this file to .env and adjust values

# App
SECRET_KEY=change-me-please
ENVIRONMENT=dev

# Database (choose ONE)
# For quick start with SQLite (no external DB needed):
DATABASE_URL=sqlite:///./vaultverse.db

# For PostgreSQL (uncomment and set values):
# DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/vaultverse

# Redis (optional initially; required for rate limits/queues/indexer)
REDIS_URL=redis://localhost:6379/0

# AWS KMS (set when enabling envelope encryption)
AWS_REGION=us-east-1
KMS_KEY_ID=
